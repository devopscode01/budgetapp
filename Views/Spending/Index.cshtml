@model BudgetApp.ViewModels.MonthSpendingVm
@using BudgetApp.Models
@{
    ViewData["Title"] = "Spending";
    ViewData["MonthYm"] = Model.MonthYm;
    var categories = Enum.GetValues<ExpenseCategory>();
    var userCategories = ViewBag.UserCategories as List<BudgetApp.Models.UserCategory> ?? new();


    string CatColor(ExpenseCategory c) {
        var id = (int)c;
        if (id >= 100) {
            var uc = userCategories.FirstOrDefault(x => x.Id == id);
            return uc?.Color ?? "#94A3B8";
        }
        return c switch {
            ExpenseCategory.Mortgage      => "#5B6EF7",
            ExpenseCategory.Utilities     => "#14B8A6",
            ExpenseCategory.Water         => "#06B6D4",
            ExpenseCategory.Groceries     => "#10B981",
            ExpenseCategory.Dining        => "#F97316",
            ExpenseCategory.Insurance     => "#F59E0B",
            ExpenseCategory.Transport     => "#8B5CF6",
            ExpenseCategory.Subscriptions => "#6366F1",
            ExpenseCategory.Healthcare    => "#EF4444",
            ExpenseCategory.Savings       => "#059669",
            ExpenseCategory.Other         => "#64748B",
            _                             => "#94A3B8"
        };
    }
    string CatLabel(ExpenseCategory c) {
        var id = (int)c;
        if (id >= 100) {
            var uc = userCategories.FirstOrDefault(x => x.Id == id);
            return uc?.Name ?? id.ToString();
        }
        return c == ExpenseCategory.Uncategorized ? "Other" : c.ToString();
    }

    var spendCats = Model.CategoryTotals
        .Where(c => c.Category != ExpenseCategory.Income)
        .OrderByDescending(c => c.Amount)
        .ToList();

    var subs = Model.Transactions
        .Where(t => t.Category == ExpenseCategory.Subscriptions)
        .Concat(Model.ManualExpenses
            .Where(m => m.Category == ExpenseCategory.Subscriptions)
            .Select(m => new ParsedTransaction { Description = m.Description, Amount = m.Amount }))
        .GroupBy(t => t.Description, StringComparer.OrdinalIgnoreCase)
        .Select(g => new { Name = g.Key, Total = g.Sum(t => t.Amount) })
        .OrderByDescending(x => x.Total)
        .ToList();
}

@{
    var activeCategory = ViewBag.ActiveCategory as string;
}

@* ── Header ─────────────────────────────────── *@
<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <h4 class="fw-bold mb-0" style="letter-spacing:-.02em">
            @Model.MonthLabel — @(activeCategory ?? "Spending")
        </h4>
        <p class="mb-0" style="font-size:.8125rem;color:var(--tm)">
            <span class="text-money fw-semibold" style="color:var(--t1)">@Model.TotalSpend.ToString("C2")</span>
            total across @spendCats.Count categories
        </p>
    </div>
    <a asp-controller="Dashboard" asp-action="Index" asp-route-ym="@Model.MonthYm"
       class="btn btn-sm btn-outline-secondary">← Dashboard</a>
</div>

@* ── Category filter chips ─────────────────── *@
<div class="mb-4" style="display:flex;flex-wrap:wrap;gap:.4rem;align-items:center">
    <a href="@Url.Action("Index", new { ym = Model.MonthYm })"
       class="cat-chip @(activeCategory == null ? "cat-chip-active" : "")">All</a>
    <a href="@Url.Action("Index", new { ym = Model.MonthYm, category = "Income" })"
       class="cat-chip @(activeCategory == "Income" ? "cat-chip-active" : "")"
       style="--chip-color:#22C55E">Income</a>
    @foreach (var cat in spendCats)
    {
        var chipActive = activeCategory == CatLabel(cat.Category) ? "cat-chip-active" : "";
        <a href="@Url.Action("Index", new { ym = Model.MonthYm, category = CatLabel(cat.Category) })"
           class="cat-chip @chipActive"
           style="--chip-color:@CatColor(cat.Category)">
            @CatLabel(cat.Category)
            <span style="opacity:.65;font-size:.75em;margin-left:.25em">@cat.Amount.ToString("C0")</span>
        </a>
    }
</div>

@* ── Subscriptions (Rocket Money style) ──────── *@
@if (subs.Any())
{
    <div class="card mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <div class="section-title mb-1">Subscriptions</div>
                <p class="mb-0" style="font-size:.8125rem;color:var(--tm)">
                    @subs.Count recurring charges · <strong class="text-money" style="color:var(--t1)">@subs.Sum(s => s.Total).ToString("C2")</strong> / mo
                    <span style="color:var(--tf)"> · ~@((subs.Sum(s => s.Total) * 12).ToString("C0")) / yr</span>
                </p>
            </div>
        </div>
        <div class="sub-grid">
            @foreach (var sub in subs)
            {
                var initials = sub.Name.Length >= 2
                    ? sub.Name.Substring(0, 2).ToUpper()
                    : sub.Name.ToUpper();
                <div class="sub-card">
                    <div class="sub-icon">@initials</div>
                    <div style="min-width:0;flex:1">
                        <div class="sub-name text-truncate" title="@sub.Name">@sub.Name</div>
                        <div class="sub-freq">Monthly</div>
                    </div>
                    <div class="sub-amt">@sub.Total.ToString("C2")</div>
                </div>
            }
        </div>
    </div>
}

@* ── Category breakdown ───────────────────────── *@
<div class="card mb-4">
    <div class="section-title">Category Breakdown</div>
    @if (!spendCats.Any())
    {
        <p class="text-muted" style="font-size:.875rem">No data for this month.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table budget-table mb-0">
                <thead>
                    <tr>
                        <th>Category</th>
                        <th class="text-end">Amount</th>
                        <th class="text-end">Txns</th>
                        <th style="width:200px">Share</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in spendCats)
                    {
                        var pct = Model.TotalSpend > 0 ? (double)(cat.Amount / Model.TotalSpend * 100) : 0;
                        var isSubscriptions = cat.Category == ExpenseCategory.Subscriptions;
                        var subItems = isSubscriptions ? subs : null;
                        <tr>
                            <td>
                                <span class="cat-badge" style="background:@(CatColor(cat.Category))22;color:@CatColor(cat.Category)">
                                    @CatLabel(cat.Category)
                                </span>
                            </td>
                            <td class="text-end text-money fw-semibold">@cat.Amount.ToString("C2")</td>
                            <td class="text-end" style="color:var(--tf)">@cat.Count</td>
                            <td>
                                <div class="prog-track mb-1">
                                    <div class="prog-fill" style="width:@pct.ToString("F1")%;background:@CatColor(cat.Category)"></div>
                                </div>
                                <small style="color:var(--tf);font-size:.7rem">@pct.ToString("F0")%</small>
                            </td>
                        </tr>
                        @if (isSubscriptions && subItems is not null)
                        {
                            @foreach (var sub in subItems)
                            {
                                <tr style="background:var(--surface-2)">
                                    <td class="ps-4" style="font-size:.8125rem;color:var(--tm)">&#8627; @sub.Name</td>
                                    <td class="text-end text-money" style="font-size:.8125rem;color:var(--tm)">@sub.Total.ToString("C2")</td>
                                    <td></td><td></td>
                                </tr>
                            }
                        }
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th>Total</th>
                        <th class="text-end text-money">@Model.TotalSpend.ToString("C2")</th>
                        <th class="text-end">@(Model.Transactions.Count + Model.ManualExpenses.Count)</th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
</div>

@* ── Transactions ─────────────────────────────── *@
<div class="card mb-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div class="section-title mb-0">Statement Transactions</div>
        <small style="color:var(--tf)">@Model.Transactions.Count items</small>
    </div>
    @if (!Model.Transactions.Any())
    {
        <p class="text-muted" style="font-size:.875rem">
            No statement transactions. <a asp-controller="Import" asp-action="Index">Import a PDF</a>.
        </p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table budget-table mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Category</th>
                        <th class="text-end">Amount</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tx in Model.Transactions)
                    {
                        var txCat = CatLabel(tx.Category);
                        var txHide = activeCategory != null && txCat != activeCategory ? "style=\"display:none\"" : "";
                        <tr data-cat="@txCat" @Html.Raw(txHide)>
                            <td class="text-nowrap" style="color:var(--tf)">@tx.PostedDate.ToString("MMM d")</td>
                            <td style="max-width:260px" class="text-truncate">@tx.Description</td>
                            <td>
                                <span class="cat-badge" style="background:@(CatColor(tx.Category))22;color:@CatColor(tx.Category)">
                                    @CatLabel(tx.Category)
                                </span>
                            </td>
                            <td class="text-end text-money">@tx.Amount.ToString("C2")</td>
                            <td style="width:64px;white-space:nowrap">
                                <button class="btn btn-link btn-xs text-muted recategorize-btn p-0"
                                        data-id="@tx.Id"
                                        data-current="@((int)tx.Category)"
                                        data-description="@tx.Description"
                                        data-amount="@tx.Amount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                        title="Edit transaction"
                                        style="font-size:1rem;line-height:1">&#9998;</button>
                                <form method="post" asp-controller="Spending" asp-action="DeleteTransaction" class="d-inline delete-tx-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ym" value="@Model.MonthYm" />
                                    <input type="hidden" name="id" value="@tx.Id" />
                                    <button type="submit" class="btn btn-link btn-xs text-muted p-0 ms-1"
                                            title="Delete transaction"
                                            style="font-size:.9rem;line-height:1;color:var(--red)!important">&#x2715;</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* ── Manual entries ───────────────────────────── *@
@if (Model.ManualExpenses.Any())
{
    <div class="card">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="section-title mb-0">Manual Entries</div>
            <a asp-controller="Manual" asp-action="Index" asp-route-ym="@Model.MonthYm"
               class="btn btn-sm btn-outline-secondary">Manage</a>
        </div>
        <div class="table-responsive">
            <table class="table budget-table mb-0">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th>Category</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model.ManualExpenses)
                    {
                        var mCat = CatLabel(m.Category);
                        var mHide = activeCategory != null && mCat != activeCategory ? "style=\"display:none\"" : "";
                        <tr data-cat="@mCat" @Html.Raw(mHide)>
                            <td>@m.Description</td>
                            <td>
                                <span class="cat-badge" style="background:@(CatColor(m.Category))22;color:@CatColor(m.Category)">
                                    @CatLabel(m.Category)
                                </span>
                            </td>
                            <td class="text-end text-money">@m.Amount.ToString("C2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* ── Edit transaction modal ───────────────────── *@
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">Edit Transaction</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-controller="Spending" asp-action="EditTransaction">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ym" value="@Model.MonthYm" />
                <input type="hidden" name="id" id="editId" />
                <div class="modal-body" style="display:flex;flex-direction:column;gap:.75rem">
                    <div>
                        <label class="form-label" style="font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.04em;color:var(--tm)">Description</label>
                        <input type="text" name="description" id="editDescription" class="form-control form-control-sm" maxlength="512" />
                    </div>
                    <div>
                        <label class="form-label" style="font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.04em;color:var(--tm)">Amount ($)</label>
                        <input type="number" name="amount" id="editAmount" class="form-control form-control-sm" step="0.01" min="0.01" />
                    </div>
                    <div>
                        <label class="form-label" style="font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.04em;color:var(--tm)">Category</label>
                        <select name="category" class="form-select form-select-sm" id="editCategory">
                            @foreach (var c in categories)
                            {
                                <option value="@((int)c)">@CatLabel(c)</option>
                            }
                            @if (userCategories.Count > 0)
                            {
                                <optgroup label="Custom">
                                @foreach (var uc in userCategories)
                                {
                                    <option value="@uc.Id">@uc.Name</option>
                                }
                                </optgroup>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.delete-tx-form').forEach(function(form) {
    form.addEventListener('submit', function(e) {
        if (!confirm('Delete this transaction?')) e.preventDefault();
    });
});
document.querySelectorAll('.recategorize-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
        document.getElementById('editId').value = btn.dataset.id;
        document.getElementById('editDescription').value = btn.dataset.description || '';
        document.getElementById('editAmount').value = btn.dataset.amount || '';
        document.getElementById('editCategory').value = btn.dataset.current;
        new bootstrap.Modal(document.getElementById('editModal')).show();
    });
});
</script>
}
