<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Budget</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <script>
    (function(){
        var t = localStorage.getItem('bgt') || 'light';
        document.documentElement.setAttribute('data-bs-theme', t);
    })();
    </script>
</head>
<body>

<nav class="app-nav">
    <a class="app-logo" href="/">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.75"/>
            <path d="M10 5v1.5M10 13.5V15M7.5 7.5C7.5 6.67 8.17 6 9 6h2.5C12.33 6 13 6.67 13 7.5S12.33 9 11.5 9h-3C7.67 9 7 9.67 7 10.5S7.67 12 8.5 12H11c.83 0 1.5.67 1.5 1.5S11.83 15 11 15H8.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
        Budget
    </a>

    <div class="nav-links">
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
           asp-controller="Dashboard" asp-action="Index">Dashboard</a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Spending" ? "active" : "")"
           asp-controller="Spending" asp-action="Index">Spending</a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Manual" ? "active" : "")"
           asp-controller="Manual" asp-action="Index">Manual</a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Debt" ? "active" : "")"
           asp-controller="Debt" asp-action="Index">Debts</a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Asset" ? "active" : "")"
           asp-controller="Asset" asp-action="Index">Assets</a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Import" ? "active" : "")"
           asp-controller="Import" asp-action="Index">Import</a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
           asp-controller="Category" asp-action="Index">Categories</a>
    </div>

    <div class="nav-right">
        <select id="monthPicker" class="month-picker" title="Select month"></select>

        @if (User.Identity?.IsAuthenticated == true)
        {
            @if (User.FindFirst("budget_admin")?.Value == "true")
            {
                <a class="nav-link" asp-controller="Admin" asp-action="Users" title="User management">Admin</a>
            }
            <a class="nav-user" asp-controller="Account" asp-action="Profile" title="Profile &amp; security">@(User.FindFirst("preferred_username")?.Value ?? User.Identity.Name)</a>
            <form method="post" asp-controller="Account" asp-action="Logout" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="theme-btn" title="Sign out">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M6 2H3a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h3M11 11l3-3-3-3M14 8H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </form>
        }

        <button class="theme-btn" id="themeToggle" title="Toggle dark / light mode" type="button">
            <svg class="icon-sun" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.5"/>
                <path d="M8 1v1.5M8 13.5V15M1 8h1.5M13.5 8H15M3.05 3.05l1.06 1.06M11.89 11.89l1.06 1.06M3.05 12.95l1.06-1.06M11.89 4.11l1.06-1.06" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <svg class="icon-moon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M13.5 9A6 6 0 0 1 7 2.5a6 6 0 1 0 6.5 6.5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>

        <button class="theme-btn nav-hamburger" id="navHamburger" title="Menu" type="button" aria-expanded="false" aria-controls="mobileMenu">
            <svg class="ham-open" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 4h12M2 8h12M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <svg class="ham-close" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:none">
                <path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
        </button>
    </div>
</nav>

<div class="mobile-menu" id="mobileMenu" hidden>
    <a class="mobile-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
       asp-controller="Dashboard" asp-action="Index">Dashboard</a>
    <a class="mobile-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Spending" ? "active" : "")"
       asp-controller="Spending" asp-action="Index">Spending</a>
    <a class="mobile-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Manual" ? "active" : "")"
       asp-controller="Manual" asp-action="Index">Manual</a>
    <a class="mobile-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Debt" ? "active" : "")"
       asp-controller="Debt" asp-action="Index">Debts</a>
    <a class="mobile-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Asset" ? "active" : "")"
       asp-controller="Asset" asp-action="Index">Assets</a>
    <a class="mobile-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Import" ? "active" : "")"
       asp-controller="Import" asp-action="Index">Import</a>
    <a class="mobile-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
       asp-controller="Category" asp-action="Index">Categories</a>
    @if (User.Identity?.IsAuthenticated == true)
    {
        @if (User.FindFirst("budget_admin")?.Value == "true")
        {
            <a class="mobile-nav-link" asp-controller="Admin" asp-action="Users">Admin</a>
        }
        <a class="mobile-nav-link" asp-controller="Account" asp-action="Profile">Profile</a>
        <form method="post" asp-controller="Account" asp-action="Logout">
            @Html.AntiForgeryToken()
            <button type="submit" class="mobile-nav-link mobile-signout">Sign out</button>
        </form>
    }
    <div class="mobile-month-row">
        <label for="monthPickerMobile" style="font-size:.8125rem;color:var(--tm);font-weight:500;">Month</label>
        <select id="monthPickerMobile" class="month-picker"></select>
    </div>
</div>

<div class="page">
    @RenderBody()
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
(function () {
    var STORE = 'bgt-ym';
    // Pages that accept a ?ym parameter
    var YM_PATHS = ['/', '/dashboard', '/spending', '/manual', '/import'];

    function pad(n) { return String(n).padStart(2, '0'); }
    function fmtYm(d) { return d.getFullYear() + '-' + pad(d.getMonth() + 1); }
    function labelYm(ym) {
        var p = ym.split('-');
        return new Date(+p[0], +p[1] - 1, 1)
            .toLocaleString('en-US', { month: 'long', year: 'numeric' });
    }

    function buildMonths() {
        var now = new Date(), out = [];
        // Start 1 month ahead, go back 3 years
        var d = new Date(now.getFullYear(), now.getMonth() + 2, 1);
        var stop = new Date(now.getFullYear() - 3, now.getMonth() - 1, 1);
        while (d > stop) {
            d = new Date(d.getFullYear(), d.getMonth() - 1, 1);
            out.push(fmtYm(d));
        }
        return out;
    }

    function fillSelect(sel, active) {
        buildMonths().forEach(function (ym) {
            var o = document.createElement('option');
            o.value = ym; o.text = labelYm(ym);
            if (ym === active) o.selected = true;
            sel.appendChild(o);
        });
    }

    function gotoMonth(ym) {
        if (!ym) return;
        localStorage.setItem(STORE, ym);
        var u = new URL(window.location.href);
        u.searchParams.set('ym', ym);
        window.location.href = u.toString();
    }

    function isYmPage(pathname) {
        var p = pathname.replace(/\/+$/, '').toLowerCase() || '/';
        // Exact match only — never redirect sub-actions like /import/upload or /import/run
        return YM_PATHS.indexOf(p) >= 0 || YM_PATHS.some(function (x) { return p === x + '/index'; });
    }

    // Determine active month: URL param > localStorage > today
    var urlYm = new URLSearchParams(window.location.search).get('ym') || '';
    var stored = localStorage.getItem(STORE) || '';
    var active = urlYm || stored || fmtYm(new Date());
    if (urlYm) localStorage.setItem(STORE, urlYm);

    // Session persistence: if this page supports ?ym but URL has none, redirect once
    if (!urlYm && stored && isYmPage(window.location.pathname)) {
        var ru = new URL(window.location.href);
        ru.searchParams.set('ym', stored);
        window.location.replace(ru.toString());
        return; // stop — new page will re-run this script with ym in URL
    }

    // Populate both selects
    ['monthPicker', 'monthPickerMobile'].forEach(function (id) {
        var sel = document.getElementById(id);
        if (!sel) return;
        fillSelect(sel, active);
        sel.addEventListener('change', function () { gotoMonth(sel.value); });
    });

    // Rewrite ym-aware nav links so clicking them keeps the selected month
    document.querySelectorAll('a.nav-link, a.mobile-nav-link').forEach(function (a) {
        var href = a.getAttribute('href');
        if (!href || /^(https?:\/\/|#|mailto:)/.test(href)) return;
        try {
            var u = new URL(href, location.origin);
            if (isYmPage(u.pathname) && !u.searchParams.has('ym')) {
                u.searchParams.set('ym', active);
                a.setAttribute('href', u.pathname + u.search);
            }
        } catch (e) {}
    });

    // Theme toggle
    var btn = document.getElementById('themeToggle');
    if (btn) {
        btn.addEventListener('click', function () {
            var html = document.documentElement;
            var next = html.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-bs-theme', next);
            localStorage.setItem('bgt', next);
            if (window.updateChartTheme) window.updateChartTheme(next);
        });
    }

    // Hamburger menu
    var ham = document.getElementById('navHamburger');
    var menu = document.getElementById('mobileMenu');
    if (ham && menu) {
        ham.addEventListener('click', function () {
            var open = !menu.hidden;
            menu.hidden = open;
            ham.setAttribute('aria-expanded', String(!open));
            ham.querySelector('.ham-open').style.display  = open ? '' : 'none';
            ham.querySelector('.ham-close').style.display = open ? 'none' : '';
        });
    }
})();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
