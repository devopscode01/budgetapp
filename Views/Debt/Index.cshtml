@model BudgetApp.ViewModels.DebtVm
@using BudgetApp.Models
@{
    ViewData["Title"] = "Debts";
    string TypeClass(DebtType t) => t switch {
        DebtType.CreditCard   => "credit",
        DebtType.AutoLoan     => "auto",
        DebtType.PersonalLoan => "personal",
        _                     => "other"
    };
    string TypeLabel(DebtType t) => t switch {
        DebtType.CreditCard   => "Credit Card",
        DebtType.AutoLoan     => "Auto Loan",
        DebtType.PersonalLoan => "Personal Loan",
        _                     => "Other"
    };
}

@* ── Header ──────────────────────────────────── *@
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h4 class="fw-bold mb-0" style="letter-spacing:-.02em">Debt Tracker</h4>
        <p class="mb-0" style="font-size:.8125rem;color:var(--tm)">Track balances and minimum payments</p>
    </div>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addDebtModal">+ Add Debt</button>
</div>

@* ── Summary cards ────────────────────────────── *@
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="metric-card">
            <div class="m-label">Total Balance</div>
            <div class="m-value text-money text-danger">@Model.TotalBalance.ToString("C0")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="metric-card">
            <div class="m-label">Min. Payments / mo</div>
            <div class="m-value text-money">@Model.TotalMinPayment.ToString("C0")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="metric-card">
            <div class="m-label">Active Debts</div>
            <div class="m-value">@Model.ActiveDebts.Count</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="metric-card">
            <div class="m-label">Paid Off</div>
            <div class="m-value text-success">@Model.PaidOffDebts.Count</div>
        </div>
    </div>
</div>

@* ── Active debts ─────────────────────────────── *@
@if (!Model.ActiveDebts.Any())
{
    <div class="card text-center py-5">
        <p style="color:var(--tm)" class="mb-2">No active debts tracked.</p>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addDebtModal">
            + Add your first debt
        </button>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        @foreach (var d in Model.ActiveDebts)
        {
            <div class="col-md-6 col-lg-4">
                <div class="debt-card @TypeClass(d.Type)">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <div class="fw-semibold" style="color:var(--t1)">@d.CreditorName</div>
                            <small style="color:var(--tm)">@TypeLabel(d.Type)
                                @if (d.InterestRate > 0)
                                {
                                    <span> · @d.InterestRate.ToString("F2")% APR</span>
                                }
                            </small>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-link btn-sm p-0" style="color:var(--tm);font-size:1.1rem"
                                    data-bs-toggle="dropdown" aria-expanded="false">&#8942;</button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <button class="dropdown-item" data-bs-toggle="modal"
                                            data-bs-target="#updateDebtModal"
                                            data-id="@d.Id"
                                            data-balance="@d.Balance"
                                            data-min="@d.MinimumPayment"
                                            data-rate="@d.InterestRate"
                                            data-due="@(d.DueDate?.ToString("yyyy-MM-dd") ?? "")"
                                            data-notes="@d.Notes">
                                        Update balance
                                    </button>
                                </li>
                                <li>
                                    <form method="post" asp-action="MarkPaid" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@d.Id" />
                                        <button type="submit" class="dropdown-item text-success"
                                                onclick="return confirm('Mark @d.CreditorName as paid off?')">
                                            Mark as paid off
                                        </button>
                                    </form>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form method="post" asp-action="Delete" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@d.Id" />
                                        <button type="submit" class="dropdown-item text-danger"
                                                onclick="return confirm('Delete @d.CreditorName?')">Delete</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                    <div class="fs-5 fw-bold text-money mb-1" style="color:var(--t1)">@d.Balance.ToString("C2")</div>
                    <div style="font-size:.8125rem;color:var(--tm)">
                        Min: <strong style="color:var(--t2)">@d.MinimumPayment.ToString("C2")</strong>
                        @if (d.DueDate.HasValue)
                        {
                            <span> · Due @d.DueDate.Value.ToString("MMM d")</span>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(d.Notes))
                    {
                        <div style="font-size:.8125rem;color:var(--tf);margin-top:.25rem">@d.Notes</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(d.AddedByName))
                    {
                        <div style="font-size:.75rem;color:var(--tf);margin-top:.3rem">Added by @d.AddedByName</div>
                    }
                </div>
            </div>
        }
    </div>
}

@* ── Paid off ─────────────────────────────────── *@
@if (Model.PaidOffDebts.Any())
{
    <div class="card">
        <div class="section-title">Paid Off 🎉</div>
        <div class="table-responsive">
            <table class="table budget-table table-sm mb-0">
                <thead><tr><th>Creditor</th><th>Type</th><th>Notes</th><th></th></tr></thead>
                <tbody>
                    @foreach (var d in Model.PaidOffDebts)
                    {
                        <tr>
                            <td style="color:var(--tm)">@d.CreditorName</td>
                            <td style="color:var(--tf)">@TypeLabel(d.Type)</td>
                            <td style="color:var(--tf)">@d.Notes</td>
                            <td style="width:32px">
                                <form method="post" asp-action="Delete" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@d.Id" />
                                    <button type="submit" class="btn btn-link btn-xs text-danger p-0"
                                            onclick="return confirm('Delete?')">&#10005;</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* ── Add Debt Modal ───────────────────────────── *@
<div class="modal fade" id="addDebtModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Debt</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="Add">
                @Html.AntiForgeryToken()
                <div class="modal-body row g-3">
                    <div class="col-12">
                        <label class="form-label">Creditor Name</label>
                        <input name="creditorName" type="text" class="form-control"
                               placeholder="e.g. Chase Sapphire, Toyota Financial" required maxlength="200" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Type</label>
                        <select name="type" class="form-select">
                            <option value="0">Credit Card</option>
                            <option value="1">Auto Loan</option>
                            <option value="2">Personal Loan</option>
                            <option value="3">Other</option>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label">Balance ($)</label>
                        <input name="balance" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" required />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Min. Payment ($)</label>
                        <input name="minimumPayment" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">APR (%)</label>
                        <input name="interestRate" type="number" step="0.01" min="0" max="100" class="form-control" placeholder="0.00" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Next Due Date</label>
                        <input name="dueDate" type="date" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Notes</label>
                        <input name="notes" type="text" class="form-control" placeholder="Optional notes" maxlength="500" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Debt</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ── Update Debt Modal ────────────────────────── *@
<div class="modal fade" id="updateDebtModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Update Balance</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="Update">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="updateId" />
                <div class="modal-body row g-3">
                    <div class="col-12">
                        <label class="form-label">Balance ($)</label>
                        <input name="balance" type="number" step="0.01" min="0" class="form-control" id="updateBalance" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Min. Payment ($)</label>
                        <input name="minimumPayment" type="number" step="0.01" min="0" class="form-control" id="updateMin" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">APR (%)</label>
                        <input name="interestRate" type="number" step="0.01" min="0" max="100" class="form-control" id="updateRate" placeholder="0.00" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Next Due Date</label>
                        <input name="dueDate" type="date" class="form-control" id="updateDue" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Notes</label>
                        <input name="notes" type="text" class="form-control" id="updateNotes" maxlength="500" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
var updateModal = document.getElementById('updateDebtModal');
updateModal.addEventListener('show.bs.modal', function(e) {
    var btn = e.relatedTarget;
    document.getElementById('updateId').value      = btn.dataset.id;
    document.getElementById('updateBalance').value = btn.dataset.balance;
    document.getElementById('updateMin').value     = btn.dataset.min;
    document.getElementById('updateRate').value    = btn.dataset.rate;
    document.getElementById('updateDue').value     = btn.dataset.due;
    document.getElementById('updateNotes').value   = btn.dataset.notes;
});
</script>
}
