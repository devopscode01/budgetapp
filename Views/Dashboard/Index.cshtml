@model BudgetApp.ViewModels.DashboardVm
@using BudgetApp.Models
@{
    ViewData["Title"] = "Dashboard";
    ViewData["MonthYm"] = Model.MonthYm;

    string CatColor(ExpenseCategory c) => c switch {
        ExpenseCategory.Mortgage      => "#5B6EF7",
        ExpenseCategory.Utilities     => "#14B8A6",
        ExpenseCategory.Water         => "#06B6D4",
        ExpenseCategory.Groceries     => "#10B981",
        ExpenseCategory.Dining        => "#F97316",
        ExpenseCategory.Insurance     => "#F59E0B",
        ExpenseCategory.Transport     => "#8B5CF6",
        ExpenseCategory.Subscriptions => "#6366F1",
        ExpenseCategory.Healthcare    => "#EF4444",
        ExpenseCategory.Savings       => "#059669",
        ExpenseCategory.Other         => "#64748B",
        _                             => "#94A3B8"
    };
    string CatLabel(ExpenseCategory c) => c == ExpenseCategory.Uncategorized ? "Other" : c.ToString();

    var income  = Model.Current.TotalIncome;
    var spent   = Model.Current.TotalSpend;
    var net     = Model.Current.NetBalance;
    var spendPct = income > 0 ? (double)(spent / income * 100) : 0;
    var heroState = income == 0 ? "state-nodata" : spendPct < 70 ? "state-good" : spendPct < 90 ? "state-watch" : "state-danger";

    var spendCats = Model.Current.CategoryTotals
        .Where(c => c.Category != ExpenseCategory.Income)
        .OrderByDescending(c => c.Amount)
        .ToList();

    // Month-over-month helpers
    var prevIncome = Model.PrevMonth?.TotalIncome ?? 0;
    var prevSpent  = Model.PrevMonth?.TotalSpend  ?? 0;
    // decimal DeltaPct(decimal cur, decimal prev) => prev == 0 ? 0 : (cur - prev) / prev * 100;
    string DeltaBadge(decimal cur, decimal prev, bool lowerIsBetter = false) {
        if (prev == 0) return "";
        var d = cur - prev;
        if (Math.Abs(d) < 0.01m) return "";
        var good = lowerIsBetter ? d < 0 : d > 0;
        var col  = good ? "#10B981" : "#EF4444";
        var sign = d > 0 ? "+" : "";
        return $"<span style='font-size:.7rem;color:{col};font-weight:600'>{sign}{d:C0} vs last mo</span>";
    }

    // Budget goal lookup
    var goalMap = Model.BudgetGoals.ToDictionary(g => (ExpenseCategory)g.Category);

    var subs = Model.Current.Transactions
        .Where(t => t.Category == ExpenseCategory.Subscriptions)
        .Concat(Model.Current.ManualExpenses
            .Where(m => m.Category == ExpenseCategory.Subscriptions)
            .Select(m => new ParsedTransaction { Description = m.Description, Amount = m.Amount }))
        .GroupBy(t => t.Description, StringComparer.OrdinalIgnoreCase)
        .Select(g => new { Name = g.Key, Total = g.Sum(t => t.Amount) })
        .OrderByDescending(x => x.Total)
        .ToList();
}

@* ── Page header ─────────────────────────────── *@
<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <h4 class="fw-bold mb-0" style="letter-spacing:-.02em">@Model.MonthLabel</h4>
        <p class="mb-0" style="font-size:.8125rem;color:var(--tm)">Monthly budget summary</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @if (income == 0)
        {
            <form method="post" asp-controller="Demo" asp-action="Seed">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ym" value="@Model.MonthYm" />
                <button type="submit" class="btn btn-sm btn-primary">Load Demo Account</button>
            </form>
        }
        <a asp-controller="Spending" asp-action="Index" asp-route-ym="@Model.MonthYm"
           class="btn btn-sm btn-outline-secondary">View Transactions →</a>
        <button type="button" class="btn btn-sm btn-outline-secondary" id="shareReportBtn"
                data-ym="@Model.MonthYm" data-label="@Model.MonthLabel">
            ↗ Share Report
        </button>
    </div>
</div>

@* ── Share Report Modal ──────────────────────── *@
<div class="modal fade" id="shareModal" tabindex="-1" aria-labelledby="shareModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background:var(--surface-2);border:1px solid var(--border)">
            <div class="modal-header" style="border-color:var(--border)">
                <h5 class="modal-title fw-semibold" id="shareModalLabel" style="font-size:.9375rem">Share Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p style="font-size:.8125rem;color:var(--tm)" class="mb-3">
                    Share your <strong id="shareMonthLabel"></strong> budget summary. The link is valid for 90 days.
                </p>

                @* Link tab *@
                <ul class="nav nav-tabs mb-3" id="shareTabs" style="font-size:.8125rem">
                    <li class="nav-item">
                        <button class="nav-link active" id="tab-link" data-bs-toggle="tab" data-bs-target="#pane-link">Copy Link</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" id="tab-users" data-bs-toggle="tab" data-bs-target="#pane-users">Internal Users</button>
                    </li>
                </ul>

                <div class="tab-content">
                    <div class="tab-pane fade show active" id="pane-link">
                        <div id="shareLoading" class="text-center py-3" style="font-size:.8125rem;color:var(--tm)">Generating link…</div>
                        <div id="shareLinkRow" class="input-group" style="display:none!important">
                            <input type="text" id="shareLinkInput" class="form-control form-control-sm" readonly
                                   style="font-size:.8125rem;background:var(--surface-1);color:var(--t1);border-color:var(--border)" />
                            <button class="btn btn-sm btn-outline-secondary" id="copyLinkBtn" type="button">Copy</button>
                        </div>
                        <p id="copySuccess" class="mt-2 mb-0" style="font-size:.8125rem;color:#10B981;display:none">✓ Copied to clipboard</p>
                    </div>

                    <div class="tab-pane fade" id="pane-users">
                        <div id="usersLoading" class="text-center py-3" style="font-size:.8125rem;color:var(--tm)">Loading users…</div>
                        <div id="usersList" style="display:none"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ── Onboarding (no data at all) ─────────────── *@
@if (Model.IsFirstMonth && !Model.Current.Transactions.Any() && !Model.Current.ManualExpenses.Any())
{
    <div class="card mb-4" style="border:2px dashed var(--border)">
        <h5 class="fw-semibold mb-1">👋 Welcome — let's set up your budget</h5>
        <p style="font-size:.8125rem;color:var(--tm)" class="mb-3">Follow these 3 steps to get your first month of data in.</p>
        <div class="row g-3">
            <div class="col-md-4">
                <div style="background:var(--surface-1);border-radius:var(--radius-sm);padding:.875rem">
                    <div style="font-size:.75rem;font-weight:700;color:var(--brand);margin-bottom:.25rem">STEP 1</div>
                    <div class="fw-semibold mb-1" style="font-size:.875rem">Record your income</div>
                    <p style="font-size:.8125rem;color:var(--tm);margin-bottom:.625rem">Add your salary or any income for this month.</p>
                    <a asp-controller="Manual" asp-action="Index" asp-route-ym="@Model.MonthYm" class="btn btn-sm btn-primary">Add income →</a>
                </div>
            </div>
            <div class="col-md-4">
                <div style="background:var(--surface-1);border-radius:var(--radius-sm);padding:.875rem">
                    <div style="font-size:.75rem;font-weight:700;color:var(--brand);margin-bottom:.25rem">STEP 2</div>
                    <div class="fw-semibold mb-1" style="font-size:.875rem">Import a bank statement</div>
                    <p style="font-size:.8125rem;color:var(--tm);margin-bottom:.625rem">Upload a PDF, TXT, or screenshot from your bank.</p>
                    <a asp-controller="Import" asp-action="Index" asp-route-ym="@Model.MonthYm" class="btn btn-sm btn-outline-secondary">Import statement →</a>
                </div>
            </div>
            <div class="col-md-4">
                <div style="background:var(--surface-1);border-radius:var(--radius-sm);padding:.875rem">
                    <div style="font-size:.75rem;font-weight:700;color:var(--brand);margin-bottom:.25rem">STEP 3</div>
                    <div class="fw-semibold mb-1" style="font-size:.875rem">Set spending goals</div>
                    <p style="font-size:.8125rem;color:var(--tm);margin-bottom:.625rem">Set monthly limits per category to stay on track.</p>
                    <a href="#budgetGoalsSection" class="btn btn-sm btn-outline-secondary">Set goals →</a>
                </div>
            </div>
        </div>
        <div class="mt-3 pt-3" style="border-top:1px solid var(--border);font-size:.8125rem;color:var(--tm)">
            Or try the demo to see how it looks with real data:
            <form method="post" asp-controller="Demo" asp-action="Seed" class="d-inline ms-2">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ym" value="@Model.MonthYm" />
                <button type="submit" class="btn btn-sm btn-primary">Load Demo Account</button>
            </form>
        </div>
    </div>
}
else if (income == 0 && !Model.Current.Transactions.Any() && !Model.Current.ManualExpenses.Any())
{
    <div class="demo-banner mb-4">
        <div class="demo-icon">💡</div>
        <div class="demo-body">
            <div class="demo-title">No data for @Model.MonthLabel</div>
            <div class="demo-desc">Add income or import a statement to get started.</div>
        </div>
        <form method="post" asp-controller="Demo" asp-action="Seed" class="flex-shrink-0">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ym" value="@Model.MonthYm" />
            <button type="submit" class="btn btn-primary">Try Demo →</button>
        </form>
    </div>
}

@* ── Hero + metric row ───────────────────────── *@
<div class="row g-3 mb-3">
    @* Safe to Spend Hero *@
    <div class="col-12 col-md-5 col-lg-4">
        <div class="hero-card @heroState h-100">
            <div class="hero-label">Safe to Spend</div>
            <div class="hero-amount">
                @if (income == 0)
                {
                    <span style="opacity:.6">—</span>
                }
                else
                {
                    @(net >= 0 ? net.ToString("C0") : "-" + (-net).ToString("C0"))
                }
            </div>
            <div class="hero-meta">
                <span>
                    <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M6.5 1.5v5l3 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><circle cx="6.5" cy="6.5" r="5.5" stroke="currentColor" stroke-width="1.4"/></svg>
                    @Model.MonthLabel
                </span>
                @if (income > 0)
                {
                    <span>@spendPct.ToString("F0")% spent</span>
                }
            </div>
        </div>
    </div>

    @* Metrics *@
    <div class="col-12 col-md-7 col-lg-8">
        <div class="row g-3 h-100">
            <div class="col-6 col-xl-3">
                <a asp-controller="Spending" asp-action="Index" asp-route-ym="@Model.MonthYm" asp-route-category="Income"
                   class="metric-card h-100" title="View income transactions">
                    <div class="m-label">Income</div>
                    <div class="m-value text-success text-money">@income.ToString("C0")</div>
                    <div class="m-sub">@Html.Raw(DeltaBadge(income, prevIncome))</div>
                </a>
            </div>
            <div class="col-6 col-xl-3">
                <a asp-controller="Spending" asp-action="Index" asp-route-ym="@Model.MonthYm"
                   class="metric-card h-100" title="View all spending">
                    <div class="m-label">Spent</div>
                    <div class="m-value text-money">@spent.ToString("C0")</div>
                    <div class="m-sub">@Html.Raw(DeltaBadge(spent, prevSpent, lowerIsBetter: true))</div>
                </a>
            </div>
            <div class="col-6 col-xl-3">
                <a asp-controller="Spending" asp-action="Index" asp-route-ym="@Model.MonthYm"
                   class="metric-card h-100" title="View transactions">
                    <div class="m-label">Net Balance</div>
                    <div class="m-value text-money @(net >= 0 ? "text-success" : "text-danger")">
                        @(net >= 0 ? "+" : "")@net.ToString("C0")
                    </div>
                    <div class="m-sub">@(net >= 0 ? "Under budget" : "Over budget") ↗</div>
                </a>
            </div>
            @if (Model.CashFlowForecast.HasValue)
            {
                var fcv = Model.CashFlowForecast.Value;
                <div class="col-6 col-xl-3">
                    <div class="metric-card h-100">
                        <div class="m-label">Month Forecast</div>
                        <div class="m-value text-money @(fcv >= 0 ? "text-success" : "text-danger")">
                            @(fcv >= 0 ? "+" : "")@fcv.ToString("C0")
                        </div>
                        <div class="m-sub" style="font-size:.7rem;color:var(--tm)">projected end-of-month</div>
                    </div>
                </div>
            }
            else
            {
                <div class="col-6 col-xl-3">
                    <a asp-controller="Spending" asp-action="Index" asp-route-ym="@Model.MonthYm"
                       class="metric-card h-100" title="View all transactions">
                        <div class="m-label">Transactions</div>
                        <div class="m-value">@(Model.Current.Transactions.Count + Model.Current.ManualExpenses.Count)</div>
                        <div class="m-sub">@Model.Current.Transactions.Count imported ↗</div>
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@* ── YNAB zero-based allocation bar ──────────── *@
@if (income > 0 && spendCats.Any())
{
    <div class="card mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <div class="section-title mb-0">Every Dollar Assigned (YNAB)</div>
            <span class="text-money" style="font-size:.8rem;color:var(--tm)">
                @spent.ToString("C0") of @income.ToString("C0") — @(net >= 0 ? net.ToString("C0") + " remaining" : (-net).ToString("C0") + " over")
            </span>
        </div>
        <div class="alloc-bar mb-2">
            @foreach (var cat in spendCats)
            {
                var segW = income > 0 ? (double)(cat.Amount / income * 100) : 0;
                <a asp-controller="Spending" asp-action="Index" asp-route-ym="@Model.MonthYm" asp-route-category="@CatLabel(cat.Category)"
                   class="alloc-seg" style="width:@segW.ToString("F2")%;background:@CatColor(cat.Category);display:block;text-decoration:none"
                   title="@CatLabel(cat.Category): @cat.Amount.ToString("C0") — click to view"></a>
            }
        </div>
        <div class="d-flex gap-3 flex-wrap" style="font-size:.75rem">
            @foreach (var cat in spendCats.Take(6))
            {
                <span style="display:flex;align-items:center;gap:.3rem;color:var(--tm)">
                    <span style="width:8px;height:8px;border-radius:50%;background:@CatColor(cat.Category);flex-shrink:0"></span>
                    @CatLabel(cat.Category)
                </span>
            }
            @if (spendCats.Count > 6)
            {
                <span style="color:var(--tf)">+@(spendCats.Count - 6) more</span>
            }
        </div>
    </div>
}

@* ── Category breakdown + Chart ──────────────── *@
<div class="row g-3 mb-3">
    <div class="col-md-7">
        <div class="card h-100">
            <div class="section-title">Spending by Category</div>
            @if (!spendCats.Any())
            {
                <p class="text-muted" style="font-size:.875rem">
                    No spending data yet.
                    <a asp-controller="Import" asp-action="Index">Import a statement</a> or
                    <a asp-controller="Manual" asp-action="Index" asp-route-ym="@Model.MonthYm">add entries manually</a>.
                </p>
            }
            else
            {
                @foreach (var cat in spendCats)
                {
                    var pct = spent > 0 ? (double)(cat.Amount / spent * 100) : 0;
                    <a asp-controller="Spending" asp-action="Index"
                       asp-route-ym="@Model.MonthYm" asp-route-category="@CatLabel(cat.Category)"
                       class="cat-row-link mb-3 p-2" title="View @CatLabel(cat.Category) transactions">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="cat-badge" style="background:@(CatColor(cat.Category))22;color:@CatColor(cat.Category)">
                                @CatLabel(cat.Category)
                            </span>
                            <div class="d-flex align-items-center gap-2">
                                <span style="font-size:.75rem;color:var(--tf)">@pct.ToString("F0")%</span>
                                <span class="fw-semibold text-money" style="font-size:.9rem;color:var(--t1)">@cat.Amount.ToString("C0")</span>
                                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" style="color:var(--tf);flex-shrink:0"><path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </div>
                        </div>
                        <div class="prog-track">
                            <div class="prog-fill" style="width:@pct.ToString("F1")%;background:@CatColor(cat.Category)"></div>
                        </div>
                    </a>
                }
            }
        </div>
    </div>

    @* Donut chart *@
    <div class="col-md-5">
        <div class="card h-100">
            <div class="section-title">Distribution</div>
            @if (!spendCats.Any())
            {
                <div class="d-flex align-items-center justify-content-center h-75" style="min-height:160px">
                    <p class="text-muted mb-0" style="font-size:.875rem">No data</p>
                </div>
            }
            else
            {
                <div class="chart-wrap">
                    <canvas id="donutChart"></canvas>
                </div>
            }
        </div>
    </div>
</div>

@* ── Budget Goals ─────────────────────────────── *@
<div class="card mb-3" id="budgetGoalsSection">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div class="section-title mb-0">Budget Goals</div>
        <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#addGoalForm">
            + Set limit
        </button>
    </div>

    <div class="collapse mb-3" id="addGoalForm">
        <form method="post" asp-controller="BudgetGoal" asp-action="Upsert" class="d-flex gap-2 flex-wrap align-items-end">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ym" value="@Model.MonthYm" />
            <div>
                <label class="form-label" style="font-size:.8125rem">Category</label>
                <select name="category" class="form-select form-select-sm" style="min-width:140px">
                    @foreach (var cat in spendCats)
                    {
                        <option value="@((int)cat.Category)">@CatLabel(cat.Category)</option>
                    }
                </select>
            </div>
            <div>
                <label class="form-label" style="font-size:.8125rem">Monthly limit ($)</label>
                <input type="number" name="limit" min="0" step="10" class="form-control form-control-sm" style="width:120px" placeholder="e.g. 500" />
            </div>
            <button type="submit" class="btn btn-sm btn-primary">Save</button>
        </form>
        <p style="font-size:.75rem;color:var(--tm)" class="mt-1 mb-0">Set limit to 0 to remove a goal.</p>
    </div>

    @if (!Model.BudgetGoals.Any() && !spendCats.Any())
    {
        <p style="font-size:.875rem;color:var(--tm)">Import transactions first, then set spending limits per category.</p>
    }
    else if (!Model.BudgetGoals.Any())
    {
        <p style="font-size:.875rem;color:var(--tm)">No goals set yet. Click "+ Set limit" to add your first monthly budget target.</p>
    }
    else
    {
        @foreach (var goal in Model.BudgetGoals)
        {
            var cat      = (ExpenseCategory)goal.Category;
            var catTotal = spendCats.FirstOrDefault(c => c.Category == cat);
            var actual   = catTotal?.Amount ?? 0m;
            var pct      = goal.MonthlyLimit > 0 ? Math.Min((double)(actual / goal.MonthlyLimit * 100), 100) : 0;
            var over     = actual > goal.MonthlyLimit;
            var barColor = pct < 70 ? "#10B981" : pct < 90 ? "#F59E0B" : "#EF4444";
            <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="cat-badge" style="background:@(CatColor(cat))22;color:@CatColor(cat)">@CatLabel(cat)</span>
                    <div class="d-flex align-items-center gap-2">
                        @if (over)
                        {
                            <span style="font-size:.75rem;color:#EF4444;font-weight:600">Over by @((actual - goal.MonthlyLimit).ToString("C0"))</span>
                        }
                        <span style="font-size:.8125rem;color:var(--tm)">@actual.ToString("C0") / @goal.MonthlyLimit.ToString("C0")</span>
                    </div>
                </div>
                <div class="prog-track">
                    <div class="prog-fill" style="width:@pct.ToString("F1")%;background:@barColor;transition:width .4s"></div>
                </div>
            </div>
        }
    }
</div>

@* ── 6-Month Trend Chart ───────────────────────── *@
@if (Model.MonthlyTrend.Any(t => t.Spend > 0 || t.Income > 0))
{
    <div class="card mb-3">
        <div class="section-title">6-Month Trend</div>
        <div style="height:160px;position:relative">
            <canvas id="trendChart"></canvas>
        </div>
    </div>
}

@* ── Subscriptions (Rocket Money style) ──────── *@
@if (subs.Any())
{
    <div class="card mb-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="section-title mb-0">Subscriptions</div>
            <div class="d-flex align-items-center gap-2">
                <span class="text-money" style="font-size:.8rem;color:var(--tm)">@subs.Sum(s => s.Total).ToString("C2") / mo</span>
                <a asp-controller="Spending" asp-action="Index" asp-route-ym="@Model.MonthYm"
                   style="font-size:.75rem;color:var(--brand)">Manage →</a>
            </div>
        </div>
        <div class="sub-grid">
            @foreach (var sub in subs)
            {
                var initials = sub.Name.Length >= 2
                    ? sub.Name.Substring(0, 2).ToUpper()
                    : sub.Name.ToUpper();
                <div class="sub-card">
                    <div class="sub-icon">@initials</div>
                    <div style="min-width:0">
                        <div class="sub-name text-truncate">@sub.Name</div>
                        <div class="sub-freq">Monthly</div>
                    </div>
                    <div class="sub-amt">@sub.Total.ToString("C2")</div>
                </div>
            }
        </div>
    </div>
}

@* ── Recent months ────────────────────────────── *@
<div class="card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="section-title mb-0">Recent Months</div>
        <a asp-controller="Import" asp-action="Index" asp-route-ym="@Model.MonthYm"
           class="btn btn-sm btn-primary">+ Import Statement</a>
    </div>
    @{
        var allMonths = new[] { Model.Current }.Concat(Model.Recent).ToList();
        var maxSpend = allMonths.Max(m => m.TotalSpend);
    }
    @foreach (var m in allMonths)
    {
        var barPct = maxSpend > 0 ? (double)(m.TotalSpend / maxSpend * 100) : 0;
        var isCurrent = m.MonthYm == Model.MonthYm;
        <div class="mb-3">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <a asp-controller="Dashboard" asp-action="Index" asp-route-ym="@m.MonthYm"
                   class="text-decoration-none" style="font-size:.875rem;font-weight:@(isCurrent ? "600" : "500");color:@(isCurrent ? "var(--t1)" : "var(--tm)")">
                    @m.MonthLabel @(isCurrent ? "← current" : "")
                </a>
                <span class="text-money" style="font-size:.875rem;font-weight:600;color:@(isCurrent ? "var(--t1)" : "var(--tm)")">
                    @m.TotalSpend.ToString("C0")
                </span>
            </div>
            <div class="prog-track">
                <div class="prog-fill @(isCurrent ? "" : "past")" style="width:@barPct.ToString("F1")%;background:@(isCurrent ? "var(--brand)" : "var(--tf)")"></div>
            </div>
        </div>
    }
</div>

@section Scripts {
@if (spendCats.Any())
{
    var chartLabels = System.Text.Json.JsonSerializer.Serialize(spendCats.Select(c => CatLabel(c.Category)));
    var chartData   = System.Text.Json.JsonSerializer.Serialize(spendCats.Select(c => c.Amount));
    var chartColors = System.Text.Json.JsonSerializer.Serialize(spendCats.Select(c => CatColor(c.Category)));
    <script>
    (function(){
        var labels = @Html.Raw(chartLabels);
        var data   = @Html.Raw(chartData);
        var colors = @Html.Raw(chartColors);
        var ym     = '@Model.MonthYm';
        var spendingBase = '@Url.Action("Index", "Spending")';
        var theme  = document.documentElement.getAttribute('data-bs-theme') || 'light';
        var isDark = theme === 'dark';

        var ctx = document.getElementById('donutChart');
        if (!ctx) return;

        var chart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: data,
                    backgroundColor: colors,
                    borderWidth: 2,
                    borderColor: isDark ? '#161928' : '#ffffff',
                    hoverBorderColor: isDark ? '#161928' : '#ffffff'
                }]
            },
            options: {
                cutout: '68%',
                animation: { animateScale: true, duration: 600 },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(ctx) {
                                var val = ctx.parsed;
                                return ' $' + val.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',') + ' — click to view';
                            }
                        }
                    }
                },
                onClick: function(evt, elements) {
                    if (!elements.length) return;
                    var cat = labels[elements[0].index];
                    window.location.href = spendingBase + '?ym=' + ym + '&category=' + encodeURIComponent(cat);
                }
            }
        });

        ctx.style.cursor = 'pointer';

        window.updateChartTheme = function(newTheme) {
            var dark = newTheme === 'dark';
            chart.data.datasets[0].borderColor = dark ? '#161928' : '#ffffff';
            chart.update('none');
        };
    })();
    </script>
}
@{
    var trendLabels = System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(t => t.Month.ToString("MMM yy")));
    var trendSpend  = System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(t => t.Spend));
    var trendIncome = System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(t => t.Income));
}
@if (Model.MonthlyTrend.Any(t => t.Spend > 0 || t.Income > 0))
{
    <script>
    (function(){
        var ctx = document.getElementById('trendChart');
        if (!ctx) return;
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(trendLabels),
                datasets: [
                    { label: 'Spent',  data: @Html.Raw(trendSpend),  backgroundColor: '#EF444488', borderColor: '#EF4444', borderWidth: 1 },
                    { label: 'Income', data: @Html.Raw(trendIncome), backgroundColor: '#10B98188', borderColor: '#10B981', borderWidth: 1 }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { labels: { font: { size: 11 }, color: getComputedStyle(document.documentElement).getPropertyValue('--tm').trim() } } },
                scales: {
                    y: { beginAtZero: true, ticks: { font: { size: 10 }, callback: function(v){ return '$' + v.toLocaleString(); } } },
                    x: { ticks: { font: { size: 10 } } }
                }
            }
        });
    })();
    </script>
}
    <script>
    (function () {
        var shareBtn   = document.getElementById('shareReportBtn');
        var modal      = new bootstrap.Modal(document.getElementById('shareModal'));
        var linkInput  = document.getElementById('shareLinkInput');
        var linkRow    = document.getElementById('shareLinkRow');
        var loading    = document.getElementById('shareLoading');
        var copyBtn    = document.getElementById('copyLinkBtn');
        var copyOk     = document.getElementById('copySuccess');
        var usersLoad  = document.getElementById('usersLoading');
        var usersList  = document.getElementById('usersList');
        var monthLabel = document.getElementById('shareMonthLabel');
        var generated  = false;
        var usersLoaded= false;

        if (!shareBtn) return;

        shareBtn.addEventListener('click', function () {
            var ym    = shareBtn.dataset.ym;
            var label = shareBtn.dataset.label;
            monthLabel.textContent = label;
            modal.show();

            if (!generated) {
                generated = true;
                var csrf = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                fetch('/Report/Share?ym=' + encodeURIComponent(ym), {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': csrf, 'X-CSRF-TOKEN': csrf }
                })
                .then(function(r) { return r.json(); })
                .then(function(d) {
                    linkInput.value = d.url;
                    loading.style.display = 'none';
                    linkRow.style.removeProperty('display');
                })
                .catch(function() {
                    loading.textContent = 'Could not generate link.';
                });
            }
        });

        copyBtn.addEventListener('click', function () {
            navigator.clipboard.writeText(linkInput.value).then(function () {
                copyOk.style.display = '';
                setTimeout(function () { copyOk.style.display = 'none'; }, 2500);
            });
        });

        document.getElementById('tab-users').addEventListener('click', function () {
            if (usersLoaded) return;
            usersLoaded = true;
            fetch('/Report/InternalUsers')
                .then(function(r) { return r.json(); })
                .then(function(users) {
                    usersLoad.style.display = 'none';
                    if (!users.length) {
                        usersList.innerHTML = '<p style="font-size:.8125rem;color:var(--tm)">No other approved users in the app.</p>';
                    } else {
                        var html = '<div class="list-group list-group-flush">';
                        users.forEach(function(u) {
                            html += '<div class="list-group-item d-flex justify-content-between align-items-center px-0" style="background:transparent;border-color:var(--border)">' +
                                '<div><div style="font-size:.875rem;font-weight:500">' + u.displayName + '</div>' +
                                '<div style="font-size:.75rem;color:var(--tm)">' + u.email + '</div></div>' +
                                '<button class="btn btn-sm btn-outline-secondary copy-user-link" data-name="' + u.displayName + '">Copy link</button>' +
                                '</div>';
                        });
                        html += '</div>';
                        usersList.innerHTML = html;
                    }
                    usersList.style.display = '';
                    usersList.querySelectorAll('.copy-user-link').forEach(function(btn) {
                        btn.addEventListener('click', function() {
                            navigator.clipboard.writeText(linkInput.value).then(function() {
                                btn.textContent = 'Copied!';
                                setTimeout(function() { btn.textContent = 'Copy link'; }, 2000);
                            });
                        });
                    });
                });
        });
    })();
    </script>
}
}
