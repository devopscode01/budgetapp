{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Budget": {
    "StatementInboxPath": "Data/Statements/Inbox",
    "StatementProcessedPath": "Data/Statements/Processed",
    "MoveFilesAfterImport": false,
    "ScanInboxRecursively": true,
    "DatabasePath": "Data/budget.db",
    "MaxUploadBytesPerFile": 52428800,
    "MortgageAmountMin": 2800,
    "MortgageAmountMax": 3050
  },
  "Keycloak": {
    "Authority": "http://localhost:8180/realms/budget",
    "ClientId": "budget-web",
    "ClientSecret": "budget-web-secret-change-me",
    "AdminUsername": "admin",
    "AdminPassword": "admin"
  }
}
