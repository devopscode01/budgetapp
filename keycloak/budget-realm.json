{
  "realm": "budget",
  "displayName": "Budget",
  "enabled": true,
  "loginWithEmailAllowed": true,
  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "rememberMe": true,
  "verifyEmail": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "accessTokenLifespan": 900,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 3600,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespan": 5184000,
  "roles": {
    "realm": [
      { "name": "budget-admin", "description": "Full admin access — can approve and manage users" },
      { "name": "budget-member", "description": "Regular household member" }
    ]
  },
  "defaultRoles": ["budget-member"],
  "clients": [
    {
      "clientId": "budget-web",
      "name": "Budget Web",
      "description": "Budget MVC web application",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "secret": "budget-web-secret-change-me",
      "redirectUris": [
        "http://localhost:8080/*",
        "http://127.0.0.1:8080/*",
        "http://host.docker.internal:8080/*"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:8080/*##http://127.0.0.1:8080/*##http://host.docker.internal:8080/*"
      },
      "protocolMappers": [
        {
          "name": "realm roles flat",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "claim.name": "roles",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "budget-mobile",
      "name": "Budget iOS",
      "description": "Budget iOS app (PKCE, future use)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "com.budget.app://*",
        "http://localhost/*"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "users": [
    {
      "username": "paul",
      "enabled": true,
      "emailVerified": true,
      "email": "paul@budget.local",
      "firstName": "Paul",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "changeme",
          "temporary": false
        }
      ],
      "realmRoles": ["budget-admin", "budget-member"]
    }
  ]
}
